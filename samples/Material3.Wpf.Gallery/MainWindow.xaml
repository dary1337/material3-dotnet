<Window x:Class="Material3.Wpf.Gallery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:m3="clr-namespace:Material3.Wpf;assembly=Material3.Wpf"
        Title="Material 3 Gallery" Height="720" Width="1060" MinWidth="860" MinHeight="560"
        WindowStyle="None" ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Surface}" UseLayoutRounding="True"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal"
        TextElement.Foreground="{DynamicResource OnSurface}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ===== window caption buttons (copied from the toolkit title bar) ===== -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariant}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="state" Background="{DynamicResource OnSurfaceVariant}" Opacity="0" CornerRadius="16" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="state" Property="Opacity" Value="0.08" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="state" Background="{DynamicResource Error}" Opacity="0" CornerRadius="16" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="state" Property="Opacity" Value="0.08" />
                                <Setter Property="Foreground" Value="{DynamicResource Error}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Tonal button (mode toggle) — M3 state layer animated via the lib's easing token ===== -->
        <Style x:Key="TonalButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{DynamicResource OnSecondaryContainer}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{DynamicResource SecondaryContainer}" CornerRadius="20">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0:0:0.13"><VisualTransition.GeneratedEasingFunction><StaticResource ResourceKey="M3StandardDecelerate" /></VisualTransition.GeneratedEasingFunction></VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver"><Storyboard><DoubleAnimation Storyboard.TargetName="st" Storyboard.TargetProperty="Opacity" To="0.08" Duration="0" /></Storyboard></VisualState>
                                    <VisualState x:Name="Pressed"><Storyboard><DoubleAnimation Storyboard.TargetName="st" Storyboard.TargetProperty="Opacity" To="0.12" Duration="0" /></Storyboard></VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid>
                                <Border x:Name="st" Background="{DynamicResource OnSecondaryContainer}" Opacity="0" CornerRadius="20" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== M3 dropdown (seed / variant) ===== -->
        <Style x:Key="M3ComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="7" Padding="11,8" Margin="0,1">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceContainerHighest}" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource SecondaryContainer}" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="M3Combo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource M3ComboItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="box" Background="{DynamicResource SurfaceContainerHighest}" CornerRadius="8"
                                                BorderBrush="{DynamicResource OutlineVariant}" BorderThickness="1">
                                            <Grid>
                                                <Border x:Name="st" Background="{DynamicResource OnSurface}" Opacity="0" CornerRadius="8" />
                                                <DockPanel Margin="14,0,8,0">
                                                    <m3:M3Icon DockPanel.Dock="Right" Kind="chevron-down" Width="20" Height="20"
                                                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" />
                                                    <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      VerticalAlignment="Center" TextElement.Foreground="{DynamicResource OnSurface}" />
                                                </DockPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="st" Property="Opacity" Value="0.05" /></Trigger>
                                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Primary}" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Pop" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                <Border Background="{DynamicResource SurfaceContainerHigh}" BorderBrush="{DynamicResource OutlineVariant}"
                                        BorderThickness="1" CornerRadius="8" Padding="5" Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ItemsPresenter />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== M3 slider (thin track, Primary fill, round thumb) ===== -->
        <Style TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{DynamicResource SurfaceContainerHighest}" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Height="4" CornerRadius="2" Background="{DynamicResource Primary}" /></ControlTemplate></RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent" /></ControlTemplate></RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18" Cursor="Hand">
                                        <Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Width="18" Height="18" Fill="{DynamicResource Primary}" /></ControlTemplate></Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== nav pill (left-aligned, like the WinForms gallery rail) ===== -->
        <Style x:Key="NavPill" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariant}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="pill" Background="Transparent" CornerRadius="20">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0:0:0.13"><VisualTransition.GeneratedEasingFunction><StaticResource ResourceKey="M3StandardDecelerate" /></VisualTransition.GeneratedEasingFunction></VisualTransition>
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="MouseOver"><Storyboard><DoubleAnimation Storyboard.TargetName="st" Storyboard.TargetProperty="Opacity" To="0.08" Duration="0" /></Storyboard></VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Grid>
                                <Border x:Name="st" Background="{DynamicResource OnSurface}" Opacity="0" CornerRadius="20" />
                                <ContentPresenter VerticalAlignment="Center" Margin="16,9" TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{DynamicResource SecondaryContainer}" />
                                <Setter Property="Foreground" Value="{DynamicResource OnSecondaryContainer}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- thin Material scrollbar (copied from the toolkit) — pill widens + brightens on scrollbar hover / drag -->
        <Style x:Key="ThinThumb" TargetType="Thumb">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="t" CornerRadius="4" Background="{DynamicResource OnSurfaceVariant}" Opacity="0.42" Margin="4,2" />
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="True">
                                <Setter TargetName="t" Property="Margin" Value="2,2" />
                                <Setter TargetName="t" Property="Opacity" Value="0.85" />
                            </DataTrigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="t" Property="Margin" Value="2,2" />
                                <Setter TargetName="t" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" /></Track.DecreaseRepeatButton>
                                <Track.Thumb><Thumb Style="{StaticResource ThinThumb}" /></Track.Thumb>
                                <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" /></Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootHost">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- title bar -->
        <Grid Grid.Row="0" Background="{DynamicResource Surface}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <Border Width="22" Height="22" CornerRadius="6" Background="{DynamicResource Primary}">
                    <m3:M3Icon Kind="layers" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource OnPrimary}" />
                </Border>
                <TextBlock Text="Material 3 Gallery" Foreground="{DynamicResource OnSurface}" FontSize="14" FontWeight="SemiBold"
                           Margin="8,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                        UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" Margin="0,0,4,0">
                    <Rectangle Width="11" Height="1" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
                <Button Style="{StaticResource CaptionButton}" Click="MaxRestore_Click" Margin="0,0,4,0">
                    <Grid>
                        <Rectangle x:Name="MaxGlyph" Width="10" Height="10" StrokeThickness="1"
                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <Grid x:Name="RestoreGlyph" Width="11" Height="11" Visibility="Collapsed">
                            <Rectangle Width="8" Height="8" StrokeThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Rectangle Width="8" Height="8" StrokeThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                       Fill="{DynamicResource Surface}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Grid>
                    </Grid>
                </Button>
                <Button Style="{StaticResource CloseCaptionButton}" Click="Close_Click">
                    <Path Data="M0,0 L10,10 M0,10 L10,0" StrokeThickness="1"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- body: nav rail + content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource Surface}">
                <StackPanel Margin="12,12,12,12">
                    <Button x:Name="ModeBtn" Style="{StaticResource TonalButton}" Content="Light theme" Click="Mode_Click" Margin="0,0,0,8" />
                    <ComboBox x:Name="SeedCombo" Style="{StaticResource M3Combo}" Margin="0,0,0,8" SelectionChanged="Seed_Changed" />
                    <ComboBox x:Name="VariantCombo" Style="{StaticResource M3Combo}" Margin="0,0,0,12" SelectionChanged="Variant_Changed" />
                    <TextBlock Text="Seed hue — drag to recolor" Style="{StaticResource Caption}" Margin="2,0,0,6" />
                    <Slider x:Name="HueSlider" Minimum="0" Maximum="360" Value="258" ValueChanged="Hue_Changed" Margin="0,0,0,18" />
                    <StackPanel x:Name="NavHost" />
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="Scroller" Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,8,8,8">
                <StackPanel x:Name="PageHost" Margin="24,8,16,24" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
