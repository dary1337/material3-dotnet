<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <!-- On .NET Framework 4.7+ the manifest's <dpiAware> only makes the PROCESS system-aware (GDI
       renders crisp). WinForms high-DPI itself — Control.DeviceDpi reporting the real DPI and
       AutoScaleMode.Dpi working — is gated on this section. Without it DeviceDpi stays 96, every
       Dpi.Scale is a no-op, and the (now larger) fonts overflow the un-scaled control heights. -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="System" />
  </System.Windows.Forms.ApplicationConfigurationSection>
</configuration>
