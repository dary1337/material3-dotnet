                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Fully templated dark context menu (the native light menu + gutter clash with the M3 surface). -->
    <Style TargetType="ContextMenu">
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{DynamicResource SurfaceContainerHigh}" BorderBrush="{DynamicResource OutlineVariant}"
                            BorderThickness="1" CornerRadius="10" Padding="5">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="7" Padding="10,7" Margin="0,1" MinWidth="180">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <m3:M3Icon x:Name="check" Grid.Column="0" Kind="Check" Width="16" Height="16"
                                         VerticalAlignment="Center" Foreground="{DynamicResource Primary}" Visibility="Collapsed" />
                            <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource OnSurface}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceContainerHighest}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{DynamicResource OutlineVariant}" Opacity="1.0" Margin="8,4" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Thin Material scrollbar — replaces the chunky native Windows one. -->
    <Style x:Key="ThinThumb" TargetType="Thumb">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <!-- OnSurfaceVariant pill, 4px idle → 8px when the scrollbar is hovered. -->
                    <Border x:Name="t" CornerRadius="4" Background="{DynamicResource OnSurfaceVariant}" Opacity="0.42" Margin="4,2" />
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="True">
                            <Setter TargetName="t" Property="Margin" Value="2,2" />
                            <Setter TargetName="t" Property="Opacity" Value="0.85" />
                        </DataTrigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Margin" Value="2,2" />
                            <Setter TargetName="t" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Themed tooltip: dark container, own shadow, wraps long text. Timing/placement are set via inheritable
         ToolTipService properties on the window root (InitialShowDelay=0, Placement=Top). -->
    <Style TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{DynamicResource SurfaceContainerHighest}" BorderBrush="{DynamicResource OutlineVariant}"
                            BorderThickness="1" CornerRadius="8" Padding="10,7" MaxWidth="320">
                        <Border.Effect><DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.55" /></Border.Effect>
                        <ContentPresenter TextElement.Foreground="{DynamicResource OnSurface}">
                            <ContentPresenter.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type m3:Chip}">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="0" />
        <Setter Property="ToolTipService.Placement" Value="Top" />
        <Setter Property="ToolTipService.ShowDuration" Value="60000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type m3:Chip}">
                    <Border x:Name="bg" CornerRadius="5" Padding="6,2" Background="{DynamicResource SurfaceContainerHighest}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <m3:M3Icon x:Name="ic" Kind="{TemplateBinding IconKind}" Width="14" Height="14"
                                         VerticalAlignment="Center" Margin="0,0,4,0" Foreground="{DynamicResource OnSurfaceVariant}" />
                            <TextBlock x:Name="tx" Text="{TemplateBinding Text}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IconKind" Value="None">
                            <Setter TargetName="ic" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Severity" Value="Primary">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource SecondaryContainer}" />
                            <Setter TargetName="ic" Property="Foreground" Value="{DynamicResource OnSecondaryContainer}" />
                            <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource OnSecondaryContainer}" />
                        </Trigger>
                        <Trigger Property="Severity" Value="Warning">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource WarningContainer}" />
                            <Setter TargetName="ic" Property="Foreground" Value="{DynamicResource OnWarningContainer}" />
                            <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource OnWarningContainer}" />
                        </Trigger>
                        <Trigger Property="Severity" Value="Error">
                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource ErrorContainer}" />
                            <Setter TargetName="ic" Property="Foreground" Value="{DynamicResource OnErrorContainer}" />
                            <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource OnErrorContainer}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Standard content card: SurfaceContainer fill, Md radius, 16 padding. -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceContainer}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Vertical popup-menu row: left-aligned content, used for dropdown overflow rows. -->
    <Style x:Key="MenuItemButton" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="Transparent" CornerRadius="{StaticResource RadiusSm}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition GeneratedDuration="0:0:0.13"><VisualTransition.GeneratedEasingFunction><StaticResource ResourceKey="M3StandardDecelerate" /></VisualTransition.GeneratedEasingFunction></VisualTransition>
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver"><Storyboard><DoubleAnimation Storyboard.TargetName="state" Storyboard.TargetProperty="Opacity" To="1" Duration="0" /></Storyboard></VisualState>
                                <VisualState x:Name="Pressed"><Storyboard><DoubleAnimation Storyboard.TargetName="state" Storyboard.TargetProperty="Opacity" To="1" Duration="0" /></Storyboard></VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid>
                            <Border x:Name="state" Background="{DynamicResource SurfaceContainerHighest}" CornerRadius="{StaticResource RadiusSm}" Opacity="0" />
                            <ContentPresenter VerticalAlignment="Center" Margin="11,8" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- App-level modal host. Wrap the window's content in one M3ModalLayer; M3Modal.Show renders cards above
         the PART_Scrim, which covers the whole layer (chrome + content) so an open modal blocks everything. -->
    <Style TargetType="{x:Type m3:M3ModalLayer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type m3:M3ModalLayer}">
                    <Grid>
                        <ContentPresenter />
                        <Border x:Name="PART_Scrim" Panel.ZIndex="1" Visibility="Collapsed" Opacity="0"
                                Margin="{TemplateBinding m3:M3ModalLayer.ChromeInset}"
                                Background="{DynamicResource Scrim}" />
                        <Grid x:Name="PART_ModalHost" Panel.ZIndex="2"
                              Margin="{TemplateBinding m3:M3ModalLayer.ChromeInset}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
